# MongoDB Configuration
MONGO_USERNAME=admin
MONGO_PASSWORD=your_password_here
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DATABASE=wrc_scraper

# MinIO Configuration
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_password_here
MINIO_HOST=localhost
MINIO_PORT=9000
MINIO_SECURE=false

# Bucket Names
LANDING_BUCKET=landing-bucket
PROCESSED_BUCKET=processed-bucket

# MongoDB Collections
LANDING_COLLECTION=landing_docs
PROCESSED_COLLECTION=processed_docs

# Scraping Configuration
PARTITION_SIZE_DAYS=30
CONCURRENT_REQUESTS=8
DOWNLOAD_DELAY=1.0
AUTOTHROTTLE_ENABLED=true
AUTOTHROTTLE_START_DELAY=1.0
AUTOTHROTTLE_MAX_DELAY=10.0
AUTOTHROTTLE_TARGET_CONCURRENCY=4.0

# Retry Configuration
RETRY_TIMES=3
RETRY_HTTP_CODES=500,502,503,504,408,429

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
